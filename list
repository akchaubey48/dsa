#include<iostream>
using namespace std;

class Node{
    public:
     int data;
     Node* next;

    Node(int data){
        this -> data=data;
        this -> next = NULL;
    }
};

void InsertAtHead(Node* &head,int d){
    Node* temp = new Node(d);
    temp -> next = head;
    head = temp;
}

void InsertAtTail(Node* &tail,int d){
    Node* temp = new Node(d);
    tail-> next=temp;
    tail= temp;

}

void InsertAtPositon(Node* &tail,Node* &head,int pos,int d){
    // handle for first index
    if(pos ==1){
        InsertAtHead(head,d);
        return ;
    }
    Node* temp=head;
    int cnt =1;
    while(cnt < pos-1){
        temp= temp ->next;
        cnt++;
    }
// handle for last index
  if(temp -> next == NULL){
      InsertAtTail(tail,d);
      return;
  }
    Node* curr = new Node(d);
     curr -> next = temp -> next;
     temp -> next= curr; 
}

// code for delete node
void deleteFirst(Node* &head){

    if(head == NULL) return ;
    Node* temp= head;
    head=temp->next;
    delete temp;
}

// delet from data
void deletedata(Node* &head,int d){
    
    // for first index
    if(head->data==d){
        deleteFirst(head);
        return;
    }
   Node* curr = head;
    while(curr->next != NULL){
        if(curr->next->data == d){
            Node* temp = curr->next;      // node to delete
            curr->next = temp->next;      // unlink
            delete temp;                  // free memory
            return;
        }
        curr = curr->next;
}
}
void print(Node* &head){
    Node* temp = head;
    
    while(temp != NULL){
        cout<< temp-> data << " ";
        temp = temp -> next;
    }
    cout<< endl;

}


